# Required for local SQLite testing only. Render wires this to Postgres through render.yaml.
DATABASE_URL=sqlite:///news.db

# Optional. If missing or quota-limited, the app uses local fallback classification.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_ENABLED=true

# Free-tier-friendly defaults. Leave MAX_FEEDS_PER_RUN blank/unset to ingest all configured feeds.
MAX_ARTICLES_PER_FEED=12
MAX_FEEDS_PER_RUN=31
FEED_CONCURRENCY=6
MAX_AI_CLASSIFICATIONS_PER_RUN=8
SESSION_TIMEOUT_MINUTES=45
EDITOR_INVITE_CODE=
