# Local development defaults. Do not commit real secrets.
DATABASE_URL=sqlite:///news.db

# Optional. Leave blank to use fallback classification.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_ENABLED=true

# Free-tier friendly defaults
MAX_ARTICLES_PER_FEED=12
MAX_AI_CLASSIFICATIONS_PER_RUN=8
SESSION_TIMEOUT_MINUTES=45
FEED_TIMEOUT_SECONDS=12
CACHE_TTL_SECONDS=300
